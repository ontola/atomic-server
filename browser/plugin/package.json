{
  "name": "@tomic/plugin",
  "type": "module",
  "version": "0.41.0-beta.0",
  "description": "Utils for building UI plugins for AtomicServer",
  "author": "Polle Pas <polle@ontola.io>",
  "license": "MIT",
  "homepage": "https://github.com/ontola/atomic-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ontola/atomic-server.git"
  },
  "bugs": {
    "url": "https://github.com/ontola/atomic-server/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format-check": "oxfmt -c ../.oxfmtrc.json --check ./src",
    "format": "oxfmt -c ../.oxfmtrc.json ./src",
    "lint": "oxlint -c ../.oxlintrc.json . && pnpm format-check",
    "lint-fix": "oxlint -c ../.oxlintrc.json --fix . && pnpm format",
    "start": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@tomic/lib": "workspace:*"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@types/node": "^25.9.1",
    "bumpp": "^11.1.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
