{
  "devDependencies": {
    "@types/node": "^24.7.0",
    "globals": "^15.11.0",
    "husky": "^8.0.3",
    "netlify-cli": "23.11.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typedoc": "^0.25.13",
    "typedoc-plugin-missing-exports": "^2.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^2.1.3"
  },
  "name": "@tomic/root",
  "version": "0.40.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run start",
    "lint": "pnpm run -r lint",
    "lint-fix": "pnpm run -r lint-fix",
    "lint-package": "pnpm run -r lint-package",
    "format-check": "pnpm run -r format-check",
    "format": "pnpm run -r format",
    "build": "pnpm --filter \"@tomic/lib\" run build && pnpm --filter=!./lib run -r build ",
    "test": "pnpm run -r test",
    "test-e2e": "pnpm run --filter @tomic/e2e test-e2e",
    "test-query": "pnpm run --filter @tomic/e2e test-query",
    "test-query-debug": "pnpm run --filter @tomic/e2e test-query-debug",
    "start": "pnpm run -r --parallel start",
    "typedoc": "typedoc --options ./typedoc.json",
    "typedoc-publish": "pnpm run typedoc && netlify link --id a628f703-2dc1-4305-93d2-4ddc16c13f75 --auth $NETLIFY_AUTH_TOKEN && netlify deploy --dir data-browser/publish/docs/ --prod --auth $NETLIFY_AUTH_TOKEN",
    "typecheck": "pnpm run -r --parallel typecheck"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pnpm run lint-fix"
    }
  },
  "workspaces": {
    "packages": [
      "e2e",
      "lib",
      "react",
      "data-browser",
      "svelte",
      "cli",
      "create-template"
    ]
  },
  "packageManager": "pnpm@10.15.1"
}
