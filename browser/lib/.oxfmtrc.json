{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "printWidth": 80,
  "tabWidth": 2,
  "singleQuote": true,
  "bracketSpacing": true,
  "useTabs": false,
  "arrowParens": "avoid",
  "jsxSingleQuote": true,
  "trailingComma": "all",
  "sortPackageJson": false,
  "ignorePatterns": ["dist", "node_modules", ".temp", "tmp"]
}
