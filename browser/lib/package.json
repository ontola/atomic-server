{
  "name": "@tomic/lib",
  "version": "0.41.0-beta.0",
  "author": "Joep Meindertsma",
  "homepage": "https://docs.atomicdata.dev/js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atomicdata-dev/atomic-server.git"
  },
  "bugs": {
    "url": "https://github.com/atomicdata-dev/atomic-server/issues"
  },
  "dependencies": {
    "@noble/ed25519": "1.6.0",
    "@noble/hashes": "^0.5.9",
    "fast-json-stable-stringify": "^2.1.0",
    "minisearch": "^7.2.0",
    "ulidx": "^2.4.1"
  },
  "description": "The Atomic Data library for typescript/javascript",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@microsoft/api-extractor": "^7.48.0",
    "@tomic/cli": "workspace:*",
    "@types/fast-json-stable-stringify": "^2.1.2",
    "loro-crdt": "^1.4.6",
    "oxfmt": "^0.42.0",
    "tslib": "^2.8.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.3"
  },
  "peerDependencies": {
    "loro-crdt": "^1.4.6"
  },
  "peerDependenciesMeta": {
    "loro-crdt": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/src/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./ontologies/*.js": {
      "types": "./dist/src/ontologies/*.d.ts",
      "import": "./dist/ontologies/*.js",
      "require": "./dist/ontologies/*.cjs"
    },
    "./client-db.worker.js": "./dist/client-db.worker.js"
  },
  "main-dev": "src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "generate-ontologies": "ad-generate ontologies",
    "lint-package": "pnpm publint && pnpm attw",
    "lint": "oxlint -c ../.oxlintrc.json ./src && pnpm format-check",
    "lint-fix": "oxlint -c ../.oxlintrc.json --fix ./src && pnpm format",
    "prepublishOnly": "pnpm run build && pnpm run lint && pnpm run lint-package",
    "format-check": "oxfmt -c ../.oxfmtrc.json --check ./src",
    "format": "oxfmt -c ../.oxfmtrc.json ./src",
    "start": "pnpm watch",
    "coverage": "vitest run --coverage",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "pnpm exec tsc --noEmit",
    "watch": "pnpm exec tsup --watch",
    "publint": "pnpm dlx publint",
    "attw": "pnpm pack --out tomic-lib.tgz && pnpm exec attw tomic-lib.tgz"
  },
  "source": "src/index.ts",
  "sideEffects": false,
  "type": "module",
  "types": "dist/src/index.d.ts"
}
