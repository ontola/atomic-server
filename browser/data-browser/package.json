  "scripts": {
    "build": "if [ \"$SKIP_WASM_BUILD\" = \"1\" ]; then echo 'SKIP_WASM_BUILD=1, skipping wasm-pack'; else pnpm build:wasm; fi && vite build",
    "build:tauri": "pnpm build:wasm && TAURI=1 vite build",
    "build:wasm": "cd ../../wasm && cargo bin wasm-pack --version && CARGO_ENCODED_RUSTFLAGS=$'--cfg\\x1fgetrandom_backend=\"wasm_js\"' cargo bin wasm-pack build --target web --out-dir pkg && cp pkg/atomic_wasm.js pkg/atomic_wasm_bg.wasm ../browser/data-browser/public/wasm/",
    "dev": "vite",
    "format-check": "oxfmt -c ../.oxfmtrc.json --check ./src",
    "format": "oxfmt -c ../.oxfmtrc.json ./src",
    "lint": "oxlint -c ../.oxlintrc.json . && pnpm format-check",
    "lint-fix": "oxlint -c ../.oxlintrc.json --fix . && pnpm format",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest run",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.build.json",
    "clean-translations": "pnpm exec wuchale --clean"
  }
