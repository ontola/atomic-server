# The atomic-server the data-browser talks to during local development.
#
# Only loaded by `vite dev` (mode=development) — production builds, which are
# served by atomic-server itself, have no such file and fall back to
# window.location.origin. This is the single knob for the "vite serves the SPA
# on a separate port from the server" dev edge case; there are no hardcoded
# vite ports anywhere in the app.
VITE_ATOMIC_SERVER_URL=http://localhost:9883
