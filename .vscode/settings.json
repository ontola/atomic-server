{
  // The linter in the CI is quite strict, so running `cargo fmt` on save is probably a good idea!
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "rust-analyzer.checkOnSave.command": "clippy",
  // Use a separate target dir so rust-analyzer's background check doesn't
  // hold the workspace `target/` lock while we run `cargo run` / `cargo test`
  // from the terminal. See planning/dev-cargo-lock-contention.md.
  "rust-analyzer.cargo.targetDir": "target/rust-analyzer",
  "rust-analyzer.check.targetDir": "target/rust-analyzer",
  // Use rustup's rust-analyzer so proc-macro ABI matches `cargo`/`rustc` (Cursor's
  // bundled analyzer can lag stable and report spurious errors on #[async_trait] etc.).
  "rust-analyzer.server.path": "rust-analyzer",
  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/build": true,
    "**/coverage": true,
    "**/dist": true
  },
  "oxc.configPath": "browser/.oxlintrc.json",
  "oxc.fmt.configPath": "browser/.oxfmtrc.json",
  "typescript.preferences.importModuleSpecifierEnding": "minimal",
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "rustTestExplorer.rootCargoManifestFilePath": "./Cargo.toml",
  // This won't work in multi-root workspaces, could be fixed by using a rust-analyzer.toml once there is some more documentation on that.
  // For now you need to set this in your own vscode settings file.
  "rust-analyzer.cargo.extraEnv": {
    "ATOMICSERVER_SKIP_JS_BUILD": "true"
  },
  "java.configuration.updateBuildConfiguration": "automatic"
}
